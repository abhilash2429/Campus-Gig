# On Render, do NOT set PORT — the platform injects it.
PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/campusgig
CLIENT_URL=http://localhost:5173
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
SUPER_ADMIN_EMAIL=superadmin@campusgig.com

# Demo only: accept any https URL for PUT /applications/:id/deliver (skip Firebase Storage validation).
# ALLOW_NON_FIREBASE_DELIVERY_URLS=true

# Optional: allow any https://*.vercel.app origin when NODE_ENV=production (demo / previews).
# Safer alternative: list every preview URL in CLIENT_URL separated by commas.
# CORS_ALLOW_VERCEL=true

